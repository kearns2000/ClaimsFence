<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <EnableNETAnalyzers>true</EnableNETAnalyzers>
    <AnalysisLevel>latest-recommended</AnalysisLevel>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
  </PropertyGroup>

  <PropertyGroup>
    <PackageId>ClaimsFence.AspNetCore</PackageId>
    <Title>ClaimsFence.AspNetCore</Title>
    <Description>ASP.NET Core integration for ClaimsFence: authorisation policy and Minimal API endpoint extensions backed by testable claim rules.</Description>
    <Authors>PKSoftLibs</Authors>
    <Company>PKSoftLibs</Company>
    <Product>ClaimsFence</Product>
    <Copyright>Copyright (c) PKSoftLibs</Copyright>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageIcon>icon.png</PackageIcon>
    <RepositoryUrl>https://github.com/kearns2000/ClaimsFence</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageProjectUrl>https://github.com/kearns2000/ClaimsFence</PackageProjectUrl>
    <PackageTags>claims;authorization;authorisation;security;aspnetcore;aspnet;webapi;minimalapi;minimal-api;identity;jwt;bearer;oauth;oidc;permissions;roles;rbac;abac;access-control;policy;authorization-handler;authorization-policy;IAuthorizationHandler;endpoint-authorization;middleware;fluent;rule-builder;testing;testable;diagnostics;ClaimsPrincipal;System.Security.Claims;tenant;multi-tenant;dotnet;net10;csharp;pksoftlibs;claimsfence;claimsfence-aspnetcore</PackageTags>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
    <ContinuousIntegrationBuild Condition="'$(GITHUB_ACTIONS)' == 'true'">true</ContinuousIntegrationBuild>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../ClaimsFence/ClaimsFence.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Include="../../README.md" Pack="true" PackagePath="\" />
    <None Include="../../assets/icon.png" Pack="true" PackagePath="\" Visible="false" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.SourceLink.GitHub" Version="8.0.0" PrivateAssets="All" />
  </ItemGroup>

</Project>
